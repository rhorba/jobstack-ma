# JobStack.ma — environment variables
# Copy to .env and fill in real values. Never commit .env.

# --- App ---
APP_BASE_URL=https://jobstack.ma          # used for CMI callback URLs, email links, CORS origin
APP_DOMAIN=jobstack.ma                     # prod only (docker-compose.prod.yml): self-signed cert CN until a real cert is dropped in — see docs/devops-jobstack.md

# --- Database (Postgres) ---
DB_NAME=jobstack
DB_USER=jobstack
DB_PASSWORD=changeme                       # strong password, container-only

# --- Auth (Spring Security / JWT) ---
JWT_SECRET=changeme-32-byte-min-signing-key # HMAC/RSA signing key for access + refresh tokens

# --- Admin seed (Story 2.5) ---
ADMIN_SEED_EMAIL=admin@jobstack.ma
ADMIN_SEED_PASSWORD=changeme

# --- CMI (Moroccan payment gateway) ---
CMI_MERCHANT_ID=changeme
CMI_STORE_KEY=changeme
CMI_API_URL=https://payment.cmi.co.ma/fim/api  # sandbox vs prod endpoint differs — confirm with CMI merchant docs
CMI_CALLBACK_URL=${APP_BASE_URL}/api/v1/payments/cmi/callback

# --- SMTP (transactional email) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=rrhorba.mohamed@gmail.com
SMTP_PASSWORD=changeme                     # Gmail App Password (Google Account > Security > App Passwords) — NOT the account login password
SMTP_FROM_ADDRESS=rrhorba.mohamed@gmail.com

# --- PostHog (analytics) ---
POSTHOG_API_KEY=changeme
POSTHOG_HOST=https://app.posthog.com
